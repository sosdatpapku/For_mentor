select
    case when count(student_name) != count(distinct student_name) then True
        else False
    end result
from students

#Задача №3 (SQL)

with stud_marks as (
    select
        s.student_id,
        count(l.mark) marks_cnt
    from students s 
    join lessons l
        on s.student_id = l.student_id
    group by s.student_id
)

select
    s.student_id,
    coalesce(sm.marks_cnt, 0) marks_cnt
from students s
left join stud_marks sm
    on s.student_id = sm.student_id

#Задача №4 (SQL)

with stud_marks as (
    select distinct
        s.student_id
    from students s 
    join lessons l
        on s.student_id = l.student_id
)

select
    s.student_id
from students s
left join stud_marks sm
    on s.student_id = sm.student_id
where sm.student_id is null

