#Задача №1 (SQL)

with user_first_purchase as (
    select
        user_id,
        amount,
        row_number() over(partition by user_id order by purchase_dt, transaction_id) rn
    from transactions
)

select
    avg(amount) avg_amount_first_purchase
from user_first_purchase
where rn = 1

#Задача №2 (SQL)

with user_act as (
    select
        user_id,
        log_type,
        dt,
        lag(dt) over(partition by user_id, log_type order by dt) prev_dt
    from event_log
),

groups as (
    select
        user_id,
        log_type,
        dt,
        sum(case when prev_dt is null or dt - prev_dt > 1 then 1 else 0 end) over(partition by user_id, log_type order by dt) grp
    from user_act
)

select
    user_id,
    log_type,
    min(dt) start_period,
    max(dt) end_period,
    count(*) lenght
from groups
group by user_id, log_type, grp
having count(*) >= 3
order by user_id, log_type, min(dt)

