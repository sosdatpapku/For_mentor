#Задача №2 (SQL)

with duplicates as (
    select
        id,
        first_name,
        last_name,
        count(*) over(partition by first_name, last_name) names_cnt
    from employee
)

select
    id,
    first_name,
    last_name
from duplicates
where names_cnt > 1
order by id

#Задача №3 (Python)

def find_largest(numbers):
    if len(numbers) == 0:
        return None

    largest = float('-inf')
    for number in numbers[1:]:
        if number > largest:
            largest = number
    return largest

