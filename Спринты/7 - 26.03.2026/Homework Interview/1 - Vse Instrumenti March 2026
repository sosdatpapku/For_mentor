# Задача №3 (Pandas)

def actual_data(items):
    items['update_time'] = pd.to_datetime(items['update_time'])
    items_filt = items.loc[items['update_time'] <= '01-06-2025']
    agg_df = items_filt.groupby('item_id', as_index=False).agg(last_act_date=('update_time', 'max'))
    res = pd.merge(items_filt, agg_df, on=['item_id', 'update_time'])
    
    return res[['item_id', 'name', 'price', 'update_time']]

