# Задача №1 (SQL)

select
    floor(sales / 50) * 50 range_start,
    floor(sales / 50) * 50 + 50 range_to,
    count(*) orders_cnt,
    sum(sales) sum_revenue
from values_table
group by floor(sales / 50)
order by floor(sales / 50)

# Задача №2 (SQL)

select
    client_id,
    case when min(year(date)) = 2022 then 'New'
        when max(year(date)) = 2022 
            and min(year(date)) = 2021 then 'LFL'
        else 'Churn'
    end client_type
from clients
group by client_id

select distinct
    client_id,
    case when min(year(date)) over(partition by client_id) = 2022 then 'New'
        when max(year(date)) over(partition by client_id) = 2022 
            and min(year(date)) over(partition by client_id) = 2021 then 'LFL'
        else 'Churn'
    end client_type
from clients

