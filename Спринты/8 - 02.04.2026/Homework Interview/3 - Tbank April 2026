#Задача №3 (SQL)

with duration_calc as (
    select
        user_id,
        session_id,
        start_time,
        start_time - lag(start_time) over(partition by user_id order by start_time, session_id) prev_session_gap,
        lead(start_time) over(partition by user_id order by start_time, session_id) - start_time next_session_gap,
        case
            when row_number() over(partition by user_id order by start_time, session_id) = 1
                then 1
            else 0
        end is_first,
        case
            when row_number() over(partition by user_id order by start_time desc, session_id desc) = 1
                then 1
            else 0
        end is_last
    from user_sessions
)

select *
from duration_calc

