with rn_data as (
    select
        user_id,
        dttm,
        action,
        row_number() over(partition by user_id order by dttm desc) rn # можно использовать rank, если хотим вытаскивать несколько записей с одинаковым временем 
    from user_logs
)

select
    user_id,
    dttm,
    action
from rn_data
where rn = 1

#Задача №5 (Python)

def change(customer_value):
    if customer_value < 1:
        return {10: 0, 5: 0, 1: 0}
    
    change_dict = {10:0, 5:0, 1:0}
    
    while customer_value != 0:
        if customer_value >= 10:
            change_dict[10] += customer_value // 10
            customer_value = customer_value % 10
        if customer_value >= 5 and customer_value < 10:
            change_dict[5] += customer_value // 5
            customer_value = customer_value % 5
        else:
            change_dict[1] += customer_value // 1
            customer_value = customer_value % 1
    
    return change_dict