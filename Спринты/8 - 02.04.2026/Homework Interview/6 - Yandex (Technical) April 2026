def find_mode(nums):
    if len(nums) == 0:
        return False

    nums_dict = {}
    for num in nums:
        nums_dict[num] = nums_dict.get(num, 0) + 1

    mode = max(nums_dict, key=nums_dict.get)
    res = []

    for item, counts in nums_dict.items():
        if counts == mode:
            res.append(item)

    return res

