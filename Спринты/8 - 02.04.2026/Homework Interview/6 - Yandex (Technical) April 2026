with duration as (
    select
        user_id,
        city,
        sum(order_duration) sum_duration
    from user_orders
    group by user_id, city
),

ranked as (
    select
        user_id,
        city,
        sum_duration,
        percent_rank() over(partition by city order by sum_duration desc) prc_rank
    from duration
)

select
    user_id,
    city,
    sum_duration
from ranked
where prc_rank <= 0.05
order by city, sum_duration desc

