#Задача №4 (SQL)

with active_users as (
    select distinct
        phone_id
    from phones
    where activity_flag = 1
        and current_date > registaration_date
        and registaration_date >= current_date - interval '1 year'
),

uber_users as (
    select distinct
        phone_id,
        install_id
    from installs
    where app_name = 'Uber'
        and is_deleted = 0
),

total_revenue as (
    select
        i.phone_id,
        sum(o.amount) sum_amount
    from orders o
    join uber_users us
        on o.install_id = us.install_id
    where o.service_name = 'taxi'
        and o.order_cancelled_flag = 0
        and o.order_date >= current_date - interval '1 month'
    group by i.phone_id
    having sum(o.amount) > 15000
)

select
    au.phone_id
from active_users au
join total_revenue tr
    on au.phone_id = tr.phone_id



    