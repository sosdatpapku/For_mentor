#Задача 1 (SQL)
Формулировка из интервью: «Есть лог цен (история цен) с датой обновления. Нужно получить актуальное состояние товаров (цен) на первую минуту/момент времени, 
    с учетом ограничения по дате (все что позже — неинтересно)».

Решение:
    with last_price_version as (
        select
            item_id,
            price,
            update_dt,
            row_number() over(partition by item_id order by update_dt desc) rn
        from price_log
        where update_dt <= :as_of_dt
    )

    select 
        item_id,
        price,
        update_dt
    from last_price_version
    where rn = 1

#Задача 2 (SQL)
Формулировка из интервью: «Есть таблица ORDERS и еще одна таблица с датой обновления (интервьюер акцентировал, что это как раз кейс для коррелированного подзапроса). 
    Нужно соединить так, чтобы для каждого заказа/объекта подтягивалась запись с максимальной update_dt, но не позже даты заказа (меньше или равно). Не забыть DISTINCT».
-- orders(order_id, item_id, order_dt, ...)
-- item_log(item_id, update_dt, attr_1, attr_2, ...)

Решение:
    select distinct
        o.order_id,
        o.item_id,
        o.order_dt,
        i.attr_1,
        i.attr_2
    from orders o
    join item_log i
        on i.item_id = o.item_id
            and i.update_dt = (
                select max(i2.update_dt)
                from item_log i2
                where i2.item_id = o.item_id
                    and i2.update_dt <= o.order_dt
            )

