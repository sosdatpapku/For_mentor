# Задача №8 (SQL)

with calc_sum as (
    select
        o.order_id,
        count(oi.order_id) items_cnt
    from orders o
    inner join order_items oi
        on o.order_id = oi.order_id
    group by o.order_id
)

select
    items_cnt,
    count(items_cnt) order_size_freq
from calc_sum
group by items_cnt
order by count(items_cnt) desc


# Задача №9 (Pandas)

df = pd.read_excel(path='/home')
df['date'] = pd.to_datetime(df['date']).dt.date

agg_df = df.groupby(['date', 'action'], as_index=False).agg(uniq_users=('user_id', 'nunique'))

pivot_df = agg_df.pivot(index='date', columns='action', values='uniq_users').fillna(0)
expected_order = ['view_banner', 'click_banner', 'add_to_cart', 'purchase']
pivot_df = pivot_df.reindex(columns=expected_order, fill_value=0)

# Задача №10 (Pandas)

