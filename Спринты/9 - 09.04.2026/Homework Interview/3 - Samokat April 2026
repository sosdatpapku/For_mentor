#Задача №2 (SQL)

with duplicates as (
    select
        id,
        count(*) over(partition by id) id_cnt
    from table1
)
select
    *
from duplicates
where id_cnt > 1

#Задача №3 (SQL)

select
    sum(o.amount * p.price) total_revenue
from orders o
inner join prices p
    on o.product_id = p.product_id
        and o.order_dt >= p.date_start
        and o.order_dt <= coalesce(p.date_end, '2030-01-01')
where o.order_dt >= dateadd(day, -7, cast(getdate() as date))

