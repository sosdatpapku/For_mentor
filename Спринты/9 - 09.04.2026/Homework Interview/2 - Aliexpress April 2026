#Задача №3 (SQL)

with agg_df as (
    select
        u.user_id,
        u.name,
        count(distinct o.order_id) orders_cnt
    from users u
    inner join orders o
        on u.user_id = o.user_id
    where status = 'done'
    group by u.user_id, u.name
),

rank_df as (
    select
        user_id,
        name,
        orders_cnt,
        percent_rank() over(order by orders_cnt desc) rank
    from agg_df
)

select
    user_id,
    name,
    orders_cnt
from rank_df
where rank <= 0.05
order by orders_cnt desc

#Задача №4 (Python)

def find_target(nums, target):
    sort_nums = sorted(nums)
    min_t, max_t = float('inf'), float('-inf')

    for i in range(len(sort_nums)):
        if sort_nums[i] == target:
            if min_t > i:
                min_t = i
            if max_t < i:
                max_t = i
    if max_t != float('-inf') and min_t != float('inf'):
      return [min_t, max_t]
    else:
      return [-1, -1]
            
