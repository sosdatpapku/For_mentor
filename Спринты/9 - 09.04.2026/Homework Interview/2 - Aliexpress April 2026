#Задача №2 (SQL)

with sum_value as (
    select
        user_id,
        order_dt,
        sum(gmv) over(partition by user_id order by order_dt) cum_sum
    from orders
    where year(getdate()) = year(order_dt)
),

filt_data as (
    select
        user_id,
        order_dt,
        cum_sum,
        row_number() over(partition by user_id order by order_dt) rn
    from sum_value
    where cum_sum >= 10000
)

select
    user_id,
    order_dt
from filt_data
where rn = 1

