#Задача №2 (SQL)

WITH month_dates AS (
    SELECT DISTINCT
        user_id,
        DATE_TRUNC('month', paid_at) AS paid_month
    FROM transactions
),
cohort_calc AS (
    SELECT
        user_id,
        MIN(paid_month) AS cohort_month
    FROM month_dates
    GROUP BY user_id
)
SELECT
    c.cohort_month,
    DATEADD(month, 1, c.cohort_month) AS next_month,
    COUNT(DISTINCT c.user_id) AS cohort_users,
    COUNT(DISTINCT CASE WHEN m.user_id IS NOT NULL THEN c.user_id END) AS returned_users,
    COUNT(DISTINCT CASE WHEN m.user_id IS NOT NULL THEN c.user_id END) * 1.0 
        / COUNT(DISTINCT c.user_id) AS retention_rate
FROM cohort_calc c
LEFT JOIN month_dates m 
    ON c.user_id = m.user_id 
    AND m.paid_month = DATEADD(month, 1, c.cohort_month)
GROUP BY c.cohort_month
ORDER BY c.cohort_month

