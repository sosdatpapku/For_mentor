#Задача №1 (SQL)

with calc_df (
select
    rti.store_id,
    ds.store_name,
    rti.goods_id,
    dg.goods_name,
    sum(rto_sum) total_rto
from rtl_txn_item rti
join dim_stores ds
    on rti.store_id = ds.store_id
join dim_goods dg
    on rti.goods_id = dg.goods_id
where rtl_txn_dt between '2025-10-01' and '2025-11-20'
group by rti.store_id, ds.store_name, rti.goods_id, dg.goods_name
),

rank_df as (
select *,
    dense_rank() over(partition by store_id, store_name order by total_rto desc) rank_in_store
from calc_df
)

select *
from rank_df
where rank_in_store <= 3
order by store_id, rank_in_store

#Задача №2 (SQL)
with receipt_agg as (
    select
        store_id,
        rtl_id,
        sum(rto_qnt) as items_in_receipt
    from rtl_txn_item
    group by store_id, rtl_id
)
select
    ra.store_id,
    ds.store_name,
    ds.city,
    count(distinct ra.rtl_id) unique_receipts,
    sum(ra.items_in_receipt) sum_qnt,
    avg(ra.items_in_receipt) avg_qnt
from receipt_agg ra
join dim_stores ds on ra.store_id = ds.store_id
group by ra.store_id, ds.store_name, ds.city
order by count(distinct ra.rtl_id) desc

