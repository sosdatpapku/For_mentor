#Задача №4 (Python)

def find_max_stonks(items, budget):
    max_stonks = 0
    for i in items:
        if i['purchase_price'] <= budget:
            profit = i['purchase_price'] - i['sell_price']
            if profit > max_stonks:
                max_stonks = profit
    
    return max_stonks


