#Задача №1 (SQL)

with month_flags as (
    select
        format(order_date, 'yyyy-mm') as order_date,
        order_id,
        user_id,
        order_price,
        first_value(format(order_date, 'yyyy-mm')) over(partition by user_id order by order_date desc) last_user_month
    from orders
),

last_month_revenue as (
    select
        user_id,
        last_user_month,
        sum(order_price) last_month_buys
    from month_flags
    group by user_id, last_user_month
),

pre_last_month_revenue as (
    select
        user_id,
        order_date,
        sum(order_price) pre_last_month_buys
    from month_flags
    where datediff(month, order_date, last_user_month) = 1
    group by user_id, order_date
),

select
    sum(last_month_buys) total_sum
from last_month_revenue lmr
join pre_last_month_revenue plmr
    on lmr.user_id = plmr.user_id
where last_month_buys > pre_last_month_buys

#Задача №2 (Python)

def find_products_below_threshold(threshold, sales_data):
    revenue = {}
    for entry in sales_data:
        item = entry[0]
        pid = item['product_id']
        qty = item['qnt']
        price = item['price']
        revenue[pid] = revenue.get(pid, 0) + qty * price

    return [pid for pid, rev in revenue.items() if rev < threshold]

