#Задача №1 (SQL)
# Первый вариант
with user_country_sum as (
    select
        user_id,
        country_id,
        sum(order_sum) user_sum
    from orders
    where order_success = 1
    group by user_id, country_id
    ),

by_country_sum as (
    select
        country_id,
        sum(order_sum) country_sum
    from orders
    where order_success = 1
    group by country_id
)

select
    ucs.user_id,
    ucs.country_id,
    user_sum * 1.0 / country_sum
from user_country_sum ucs
join by_country_sum bcs
    on ucs.country_id = bcs.country_id

# Второй вариант
WITH user_sums AS (
    SELECT
        user_id,
        country_id,
        SUM(order_sum) AS user_sum
    FROM orders
    WHERE order_success = 1
    GROUP BY user_id, country_id
)
SELECT
    user_id,
    country_id,
    user_sum * 1.0 / SUM(user_sum) OVER (PARTITION BY country_id) AS ratio
FROM user_sums

