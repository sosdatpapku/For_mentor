#Задача №3 (Python)

def find_1_2_max(l):
    if len(l) < 2:
        return l[0], None

    first_max, sec_max = float('-inf'), float('-inf')

    for i in l:
        if i > first_max:
            sec_max = first_max
            first_max = i
        elif i > sec_max:
            sec_max = i
    return first_max, sec_max

