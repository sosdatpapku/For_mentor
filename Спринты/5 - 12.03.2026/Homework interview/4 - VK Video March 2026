#Задача №1 (SQL)

select
    campaing_id,
    event_type,
    count(event_id) event_cnt
from ads a
left join events e
    on a.ad_id = e.ad_id
group by campaing_id, event_type

#Задача №2 (SQL)

select
    campaing_id,
    round(sum(case when event_type = 'click' then 1 else 0 end) * 1.0 / nullif(sum(case when event_type = 'impression' then 1 else 0 end) * 100, 0), 2) ctr
from ads a
left join events e
    on a.ad_id = e.ad_id
group by campaing_id

