    points
    dense_rank() over(order by points) rank
from competitors

#Задача №4 (Python)

def rle(s):
    if s == '':
        return ''
    res = []
    i = 0
    n = len(s)
    while i < n:
        char = s[i]
        j = i
        while j < n and s[j] == char:
            j += 1
        count = j - i
        res.append(char)
        if count > 1:
            res.append(str(count))
        i = j
    return ''.join(res)

