#Задача №5 (SQL)
Формулировка в транскрибации частично шумная, но по обсуждению задача восстанавливается так:
    нужно для пользователей посчитать среднюю длительность сессии в феврале и присоединить флаг, был ли у пользователя хотя бы один успешный заказ в марте.

with feb_sessions as (
    select
        user_id,
        session_id,
        min(dttm) session_start,
        max(dttm) session_end
    from events
    where dttm >= '2026-02-01' and dttm < '2026-03-01'
    group by user_id, session_id
),
feb_session_dur as (
    select
        user_id,
        session_id,
        datediff(second, session_end, session_start) session_duration
    from feb_sessions
),

feb_session_dur_avg as (
    select
        user_id,
        avg(session_duration) avg_session_duration
    from feb_session_dur
    group by user_id
),

mar_orders as (
    select distinct
        user_id,
        1 success_order
    from orders
    where dttm >= '2026-03-01' and dttm < '2026-04-01'
        and is_success = 1
)

select
    fsda.user_id,
    fsda.avg_session_duration,
    coalesce(mo.success_order, 0) success_order_in_march
from feb_session_dur_avg fsda
left join mar_orders mo
    on fsda.user_id = mo.user_id

#Задача №6 (Python)
Нужно написать базовую функцию, которая определяет, является ли число простым. В разговоре отдельно обсуждался кейс с единицей.

def is_prime(n):
    if n < 2:
        return False
    for i in range(2, int(n ** 0.5) + 1):
        if n % i == 0:
            return False
    return True

