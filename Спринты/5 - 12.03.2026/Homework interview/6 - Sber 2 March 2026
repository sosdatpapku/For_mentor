#Задача №1 (SQL)
Вывести уникальные названия всех продуктов банка

select distinct
    product_name
from products

#Задача №2 (SQL)
Вывести id клиентов, по которым не было ни одной коммуникации

select
    c.client_id
from clients c
left join communications com
    on c.client_id = com.client_id
where com.client_id is null

#Задача №3 (SQL)
Вывести только 5 продуктов по количеству коммуникаций за месяц

with agg_df as (
    select
        product_id,
        count(*) com_cnt
    from communications
    where format(dttm, 'yyyy-mm') = '2024-03'
    group by product_id
),

rank_df as (
    select
        product_id,
        com_cnt,
        dense_rank() over(order com_cnt desc) rank
    from agg_df
)

select
    product_id,
    com_cnt
from rank_df
where rank <= 5

#Задача №4 (SQL)
Вывести суммарный NPV по продукту и каналу

select
    product_id,
    channel_id,
    sum(npv) sum_npv
from communications
group by product_id, channel_id

#Задача №5 (SQL)
Вывести ФИО клиента и кумулятивную сумму NPV по всем его коммуникациям

select
    c.client_id,
    c.client_name,
    com.communication_id,
    com.dttm,
    sum(npv) over(partition by c.client_name order by com.dttm asc) cum_sum
from communications com
join clients c 
    on com.client_id = c.client_id
order by c.client_id, com.dttm

